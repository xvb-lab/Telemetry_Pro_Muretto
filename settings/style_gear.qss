/* Gear — estratto esatto dal blocco gear dell'HUD (style_hud.qss) */
#overlay   { background: transparent; }
#container { background: transparent; }

#gsBox {
    background: rgba(20,24,30,1.0);
    border-radius: 4px;
}
#hudGear {
    color: #ffffff;
    font-size: 34px;
    font-weight: bold;
}
#hudSpeed {
    color: #c5ccd6;
    font-size: 15px;
    font-weight: bold;
}
